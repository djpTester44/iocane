.ruff_cache/

# -----------------------------------------------------------------------------

# Iocane: skill-creator eval machinery

# -----------------------------------------------------------------------------

# These are only loaded explicitly when running skill evals. Indexing them
# globally adds ~2000 tokens of noise to every session

.claude/skills/skill-creator/scripts/
.claude/skills/skill-creator/agents/
.claude/skills/skill-creator/assets/
.claude/skills/skill-creator/eval-viewer/
.claude/skills/skill-creator/references/
.claude/skills/skill-creator/LICENSE.txt

# Keep: .claude/skills/skill-creator/SKILL.md

# Rationale: the SKILL.md is the interface — Claude needs to know the skill
# exists and how to invoke it. The implementation scripts do not need indexing

# -----------------------------------------------------------------------------

# Iocane: templates directory

# -----------------------------------------------------------------------------

# Templates are loaded explicitly by workflows that need them (io-init loads
# project-spec.md template, io-architect loads interface.pyi.template, etc.)
# Indexing them globally causes Claude to treat forward-declaration stubs as
# actual project state, which produces false gap analysis findings

.claude/templates/

# -----------------------------------------------------------------------------

# Iocane: execution logs

# -----------------------------------------------------------------------------

# plans/progress.md is retired (io-loop era) — no workflow creates it.
# Entry kept to prevent accidental creation from being auto-indexed.

plans/progress.md

# -----------------------------------------------------------------------------

# Iocane: task execution artifacts (per-checkpoint logs, exit codes, status)

# -----------------------------------------------------------------------------

# .log and .exit files are written by sub-agents during execution.
# They can be large and are only needed for post-mortem analysis — not for
# normal orchestration or review workflows. Load explicitly when needed.

plans/tasks/*.log
plans/tasks/*.exit

# -----------------------------------------------------------------------------

# Iocane: git worktrees

# -----------------------------------------------------------------------------

# .worktrees/ contains full repo checkouts for each concurrent sub-agent.
# These are large and ephemeral — never index them. Sub-agents operate inside
# worktrees and should not read the parent .worktrees/ directory.

.worktrees/

# -----------------------------------------------------------------------------

# Iocane: escalation state

# -----------------------------------------------------------------------------

# .iocane/ contains escalation.log and escalation.flag. The log can grow large
# over a multi-session project. session-start.sh and /io-orchestrate read only
# escalation.flag (a tiny sentinel). The log is read explicitly by the human
# after an escalation event — it must never be indexed globally.

.iocane/

# -----------------------------------------------------------------------------

# Iocane: walkthrough and digest artifacts

# -----------------------------------------------------------------------------

# These are packaging outputs, not source files. The digest.txt in particular
# can be enormous and contains redundant copies of everything else

*.digest.txt
digest.txt
walkthrough.md
plans/walkthrough.md
current-state.md
plans/current-state.md

# -----------------------------------------------------------------------------

# Secrets and environment

# -----------------------------------------------------------------------------

.env
.env.*
!.env.example
secrets/
*.pem
*.key
*.cert

# -----------------------------------------------------------------------------

# IDE and editor state

# -----------------------------------------------------------------------------

.vscode/settings.json
.vscode/launch.json
.idea/
*.iml

# -----------------------------------------------------------------------------

# CI/CD artifacts

# -----------------------------------------------------------------------------

.github/workflows/
