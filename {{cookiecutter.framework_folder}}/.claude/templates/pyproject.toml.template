[project]
name = "__PROJECT_NAME__"
version = "0.1.0"
description = "__PROJECT_DESCRIPTION__"
readme = "README.md"
requires-python = ">=__PYTHON_VERSION__"
dependencies = []

[dependency-groups]
dev = [
    "bandit>=1.8",
    "import-linter>=2.10",
    "jinja2>=3.1",
    "mypy>=1.19.1",
    "pydantic>=2.12.5",
    "pytest>=9.0.2",
    "pytest-cov>=7.0.0",
    "pytest-mock>=3.15.1",
    "pyyaml>=6.0.3",
    "ruff>=0.14.13",
]

[tool.ruff]
line-length = 88
target-version = "py__PYTHON_VERSION_NODOT__"

[tool.ruff.lint]
select = ["E", "F", "I", "N", "W", "UP", "B", "C4", "SIM", "S110", "D100", "T201"]
ignore = ["E501"]

[tool.ruff.format]
quote-style = "double"
indent-style = "space"

[tool.ruff.lint.per-file-ignores]
".claude/scripts/check_*.py" = ["T201"]

[tool.pytest.ini_options]
testpaths = ["tests"]
python_files = ["test_*.py"]
addopts = "-v --tb=short"
pythonpath = ["."]

[tool.mypy]
python_version = "__PYTHON_VERSION__"
strict = true

[tool.importlinter]
root_packages = [__ROOT_PACKAGES__]

# [[tool.importlinter.contracts]] populated by /io-architect
