{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/session-start.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/write-gate.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/di-gate.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/forbidden-tools.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/reset-on-prd-write.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/reset-on-project-spec-write.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/reset-on-plan-write.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/reset-on-pyi-write.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/backlog-id-assign.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/escalation-gate.sh"
          }
        ]
      }
    ]
  }
}
